rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to get current user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper checks for roles
    function isServo() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@amoi.org' || 
        request.auth.token.email == 'admin@ministerioamoi.it.ao' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Servo de Deus' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'servo de deus'
        ))
      );
    }

    // Apenas quem é Editor ou Servo de Deus (Admin)
    function isEditorOrServo() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@amoi.org' || 
        request.auth.token.email == 'admin@ministerioamoi.it.ao' ||
        request.auth.token.email == 'editor@amoi.org' || 
        request.auth.token.email == 'editor@ministerioamoi.it.ao' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Editor' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Servo de Deus' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'servo de deus'
        ))
      );
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Qualquer pessoa autenticada pode ler perfis
      allow read: if isSignedIn();
      // O próprio usuário pode se registrar/editar, ou um Servo de Deus pode alterar dados de membros
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isServo());
      // Apenas Servo de Deus pode excluir contas de utilizadores
      allow delete: if isServo();
    }

    // --- Password Resets ---
    match /password_resets/{email} {
      // Aberto para leitura/gravação pública para viabilizar o fluxo de redefinição sem autenticação
      allow read, write: if true;
    }

    // --- Trigger Email Mail Queue ---
    match /mail/{mailId} {
      // Apenas Editores ou Servos de Deus podem enviar e-mails de newsletter
      allow create: if isEditorOrServo();
      // Bloquear leitura/escrita para outros fins por segurança e privacidade
      allow read, update, delete: if false;
    }

    // --- Carousel Slides ---
    match /carousel_slides/{slideId} {
      // Público pode ver slides
      allow read: if true;
      // Apenas Editores ou Servos de Deus podem modificar
      allow write: if isEditorOrServo();
    }

    // --- Announcements / News ---
    match /announcements/{annId} {
      // Público pode ver publicações
      allow read: if true;
      // Apenas Editores ou Servos de Deus podem modificar
      allow write: if isEditorOrServo();
    }

    // --- Church Page General Copy & Schedules ---
    match /church_info/{infoId} {
      // Público pode ver informações
      allow read: if true;
      // Apenas Editores ou Servos de Deus podem modificar
      allow write: if isEditorOrServo();
    }

    // --- General Settings ---
    match /settings/{settingId} {
      // Apenas Editores ou Servos de Deus podem visualizar e configurar definições globais
      allow read, write: if isEditorOrServo();
    }

    // --- Videos (YouTube & Curtos) ---
    match /videos/{videoId} {
      // Público pode ver vídeos
      allow read: if true;
      // Apenas Editores ou Servos de Deus podem modificar
      allow write: if isEditorOrServo();
    }

    // --- Servants (O Chamado) ---
    match /servants/{servantId} {
      // Público pode ler servos
      allow read: if true;
      // Apenas Editores ou Servos de Deus podem modificar
      allow write: if isEditorOrServo();
    }
  }
}
