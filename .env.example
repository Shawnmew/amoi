# Firebase Configuration placeholders. Replace with your credentials from the Firebase Console.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Brevo (Sendinblue) - Envio de email com anexo PDF
VITE_BREVO_API_KEY=your-brevo-api-key

# Configurações de E-mail SMTP (opcional - para SSR)
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=587
SMTP_USER=seu-email@seudominio.com
SMTP_PASS=sua-palavra-passe
SMTP_FROM="AMOI" <seu-email@seudominio.com>
